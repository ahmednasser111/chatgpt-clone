HF_API_KEY=
DATABASE_URL="file:./dev.db"

# Only needed when DATABASE_URL points at a remote libsql/Turso database
# (e.g. deploying to Vercel — local file: URLs don't need this).
TURSO_AUTH_TOKEN=

# ITI student API proxy (Student Bedrock Gateway)
ITI_API_KEY=
ITI_BASE_URL=http://apiaccess.iti.net.eg
ITI_CHAT_PATH=/api/v1/student/chat

# Local Ollama — only needed for local models and RAG embeddings.
OLLAMA_BASE_URL=http://localhost:11434
